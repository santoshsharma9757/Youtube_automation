      "text": "baar-baar fitness journey shuru"
    },
    {
      "start": 5.225454545454545,
      "end": 6.967272727272727,
      "text": "karte ho? Is all-or-nothing"
    },
    {
      "start": 6.967272727272727,
      "end": 8.709090909090909,
      "text": "mindset se hi sab"
    },
    {
      "start": 8.709090909090909,
