      "text": "lo, har din ek"
    },
    {
      "start": 27.869090909090907,
      "end": 29.61090909090909,
      "text": "choti victory hai. Focus"
    },
    {
      "start": 29.61090909090909,
      "end": 31.35272727272727,
      "text": "karo, ek exercise se"
    },
    {
      "start": 31.35272727272727,
      "end": 33.094545454545454,
      "text": "shuru karo. Gym, yoga,"
    },
    {
      "start": 33.094545454545454,
      "end": 34.836363636363636,
      "text": "ya sirf walk shuru"
    },
    {
      "start": 34.836363636363636,
      "end": 36.57818181818182,
      "text": "karo, par na rukna."
    },
    {
      "start": 36.57818181818182,
      "end": 38.32,
      "text": "Strength build karo. Aaj"
    },
    {
      "start": 38.32,
      "end": 40.06181818181818,
      "text": "se ek habit lo,"
    },
    {
      "start": 40.06181818181818,
      "end": 41.803636363636365,
      "text": "10 din tak consistent"
    },
    {
      "start": 41.80363636363636,
      "end": 43.54545454545454,
      "text": "raho! Lifelong change chahiye"
    },
    {
      "start": 43.54545454545454,
