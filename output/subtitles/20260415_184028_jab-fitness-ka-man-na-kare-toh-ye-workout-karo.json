{
  "segments": [
    {
      "start": 0.0,
      "end": 1.9604123711340207,
      "text": "Ruk mat! Aaj fitness"
    },
    {
      "start": 1.9604123711340207,
      "end": 3.9208247422680413,
      "text": "ka man nahi hai?"
    },
    {
      "start": 3.9208247422680413,
      "end": 5.881237113402062,
      "text": "Sabko hota hai, jab"
    },
    {
      "start": 5.881237113402062,
      "end": 7.841649484536083,
      "text": "exercise karne ka man"
    },
    {
      "start": 7.841649484536083,
      "end": 9.802061855670104,
      "text": "na kare. Motivation khatam!"
    },
    {
      "start": 9.802061855670104,
      "end": 11.762474226804125,
      "text": "Yeh phase dangerous hai."
    },
    {
      "start": 11.762474226804123,
      "end": 13.722886597938144,
      "text": "Lekin yeh samajh lo,"
    },
    {
      "start": 13.722886597938144,
      "end": 15.683298969072165,
      "text": "body ko chhoti-chhoti workouts"
    },
    {
      "start": 15.683298969072165,
      "end": 17.643711340206185,
      "text": "chahiye. Kyunki consistency se"
    },
    {
      "start": 17.643711340206185,
      "end": 19.604123711340204,
      "text": "hi dikhta hai result."
    },
    {
      "start": 19.604123711340208,
      "end": 21.564536082474227,
      "text": "Toh aaj chalo, sirf"
    },
    {
      "start": 21.564536082474227,
      "end": 23.524948453608246,
      "text": "15 minutes ki low-intensity"
    },
    {
      "start": 23.524948453608246,
      "end": 25.485360824742266,
      "text": "workout karein. Bas push-ups,"
    },
    {
      "start": 25.48536082474227,
      "end": 27.44577319587629,
      "text": "squats, aur planks. Yeh"
    },
    {
      "start": 27.44577319587629,
      "end": 29.406185567010308,
      "text": "tough lag raha hai?"
    },
    {
      "start": 29.40618556701031,
      "end": 31.36659793814433,
      "text": "Chalo, thoda dumbbells uthao"
    },
    {
      "start": 31.36659793814433,
      "end": 33.32701030927835,
      "text": "aur apne muscles ko"
    },
    {
      "start": 33.32701030927835,
      "end": 35.28742268041237,
      "text": "activate karo. Body ko"
    },
    {
      "start": 35.28742268041237,
      "end": 37.24783505154639,
      "text": "chahiye woh consistency aur"
    },
    {
      "start": 37.247835051546396,
      "end": 39.208247422680415,
      "text": "discipline. Ab yeh workout"
    },
    {
      "start": 39.208247422680415,
      "end": 41.168659793814435,
      "text": "karo aur apne fitness"
    },
    {
      "start": 41.168659793814435,
      "end": 43.129072164948454,
      "text": "streak ko alive rakho!"
    },
    {
      "start": 43.129072164948454,
      "end": 45.08948453608247,
      "text": "Save karo, share karo"
    },
    {
      "start": 45.08948453608247,
      "end": 47.04989690721649,
      "text": "aur DailyFitX ka hissa"
    },
    {
      "start": 47.04989690721649,
      "end": 47.54,
      "text": "bano!"
    }
  ]
}