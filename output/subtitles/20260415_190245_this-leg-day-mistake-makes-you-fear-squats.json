{
  "segments": [
    {
      "start": 0.0,
      "end": 1.7605925925925927,
      "text": "Agar tumhe squats se"
    },
    {
      "start": 1.7605925925925927,
      "end": 3.5211851851851854,
      "text": "dar lagta hai, toh"
    },
    {
      "start": 3.5211851851851854,
      "end": 5.281777777777778,
      "text": "ruk mat! Yeh sab"
    },
    {
      "start": 5.281777777777778,
      "end": 7.042370370370371,
      "text": "tumhe fail kar raha"
    },
    {
      "start": 7.042370370370371,
      "end": 8.802962962962964,
      "text": "hai. Leg day se"
    },
    {
      "start": 8.802962962962964,
      "end": 10.563555555555556,
      "text": "bhag na jao. Yeh"
    },
    {
      "start": 10.563555555555556,
      "end": 12.324148148148149,
      "text": "sirf ek workout nahi"
    },
    {
      "start": 12.324148148148149,
      "end": 14.084740740740742,
      "text": "hai, it's a mindset"
    },
    {
      "start": 14.084740740740742,
      "end": 15.845333333333334,
      "text": "issue. Jab bhi tum"
    },
    {
      "start": 15.845333333333334,
      "end": 17.605925925925927,
      "text": "squats karte ho, toh"
    },
    {
      "start": 17.605925925925927,
      "end": 19.366518518518518,
      "text": "kya feel karte ho?"
    },
    {
      "start": 19.366518518518518,
      "end": 21.127111111111113,
      "text": "Pain ya fear? Doston,"
    },
    {
      "start": 21.127111111111113,
      "end": 22.887703703703707,
      "text": "jab tumhara form kharab"
    },
    {
      "start": 22.887703703703707,
      "end": 24.6482962962963,
      "text": "hota hai, toh muscles"
    },
    {
      "start": 24.648296296296298,
      "end": 26.40888888888889,
      "text": "sahi se respond nahi"
    },
    {
      "start": 26.40888888888889,
      "end": 28.169481481481483,
      "text": "karte. Biologically, tum jab"
    },
    {
      "start": 28.169481481481483,
      "end": 29.930074074074078,
      "text": "consistent nahi hote, toh"
    },
    {
      "start": 29.930074074074078,
      "end": 31.690666666666672,
      "text": "tumhe fat loss nahi"
    },
    {
      "start": 31.69066666666667,
      "end": 33.45125925925926,
      "text": "milega. Yeh tumhari confidence"
    },
    {
      "start": 33.45125925925926,
      "end": 35.211851851851854,
      "text": "ko tod deta hai."
    },
    {
      "start": 35.211851851851854,
      "end": 36.97244444444445,
      "text": "Toh solution kya hai?"
    },
    {
      "start": 36.97244444444445,
      "end": 38.73303703703704,
      "text": "Pehle apna form check"
    },
    {
      "start": 38.733037037037036,
      "end": 40.49362962962963,
      "text": "karo. Squats se pehle"
    },
    {
      "start": 40.49362962962963,
      "end": 42.254222222222225,
      "text": "bodyweight squats karo, dhyan"
    },
    {
      "start": 42.254222222222225,
      "end": 44.01481481481482,
      "text": "se. Phir gradually weight"
    },
    {
      "start": 44.01481481481482,
      "end": 45.775407407407414,
      "text": "badhao. Consistency aur discipline"
    },
    {
      "start": 45.775407407407414,
      "end": 47.53600000000001,
      "text": "se tumhe 30 din"
    },
    {
      "start": 47.536,
      "end": 49.296592592592596,
      "text": "mein transform feel hoga."
    },
    {
      "start": 49.296592592592596,
      "end": 51.05718518518519,
      "text": "Ab bas excuse band"
    },
    {
      "start": 51.05718518518519,
      "end": 52.817777777777785,
      "text": "karo! Aaj se leg"
    },
    {
      "start": 52.81777777777778,
      "end": 54.57837037037037,
      "text": "day ko enjoy karna"
    },
    {
      "start": 54.57837037037037,
      "end": 56.33896296296297,
      "text": "shuru karo! Comment karo"
    },
    {
      "start": 56.33896296296297,
      "end": 58.09955555555556,
      "text": "'I will squat' agar"
    },
    {
      "start": 58.09955555555556,
      "end": 59.42,
      "text": "tum ready ho!"
    }
  ]
}